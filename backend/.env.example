# Supabase PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Use port 6543 for pooled (production), 5432 for direct (migrations)
DATABASE_URL=postgresql://postgres:your_password@db.your-project-ref.supabase.co:6543/postgres

# Admin password for the dashboard login
# Must mirror VITE_ADMIN_PASSWORD in frontend/.env
ADMIN_PASSWORD=your_admin_password_here
